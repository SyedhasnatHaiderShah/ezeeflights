{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (NestJS)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/backend"],
      "port": 4000,
      "autoPort": false
    },
    {
      "name": "Frontend (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "apps/frontend"],
      "port": 3000,
      "autoPort": false
    }
  ]
}
