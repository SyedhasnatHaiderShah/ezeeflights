# Shared
NODE_ENV=development

# Backend
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ezeeflights
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
JWT_SECRET=replace-me-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=14
FRONTEND_ORIGIN=http://localhost:3000
# Where Google OAuth redirects after callback (usually your Next.js origin)
FRONTEND_OAUTH_REDIRECT=http://localhost:3000
# 32-byte key as 64 hex chars (openssl rand -hex 32)
AUTH_ENCRYPTION_KEY=
BACKUP_CODE_PEPPER=
TOTP_ISSUER=ezeeFlights
LOG_LEVEL=info
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Full callback URL as registered in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
OPENAI_API_KEY=
ADMIN_EMAILS=admin@ezeeflights.com

EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@ezeeflights.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
TWILIO_WHATSAPP_FROM=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
# Server-side BFF → Nest (browser never calls this in production)
INTERNAL_API_BASE_URL=http://localhost:4000

# Loyalty
LOYALTY_POINTS_EXPIRY_DAYS=365

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYTABS_SERVER_KEY=
TABBY_API_KEY=
TAMARA_API_KEY=
# Booking Engine
BOOKING_SERVICE_FEE_PERCENT=3
BOOKING_MAX_PASSENGERS=9
