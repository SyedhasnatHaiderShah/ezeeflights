# Backend
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ezeeflights
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-strong-secret
BOOKING_COM_API_KEY=
EXPEDIA_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
ENABLE_LEGACY_PAYMENT_BRIDGE=false
# Server-side BFF → Nest (browser never calls this in production)
INTERNAL_API_BASE_URL=http://localhost:4000

# Loyalty
LOYALTY_POINTS_EXPIRY_DAYS=365

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYTABS_SERVER_KEY=
TABBY_API_KEY=
TAMARA_API_KEY=
# Booking Engine
BOOKING_SERVICE_FEE_PERCENT=3
BOOKING_MAX_PASSENGERS=9
