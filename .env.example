# Backend
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ezeeflights
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-strong-secret
BOOKING_COM_API_KEY=
EXPEDIA_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
ENABLE_LEGACY_PAYMENT_BRIDGE=false
# Server-side BFF → Nest (browser never calls this in production)
INTERNAL_API_BASE_URL=http://localhost:4000

# Loyalty
LOYALTY_POINTS_EXPIRY_DAYS=365

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYTABS_SERVER_KEY=
TABBY_API_KEY=
TAMARA_API_KEY=
# Booking Engine
BOOKING_SERVICE_FEE_PERCENT=3
BOOKING_MAX_PASSENGERS=9

# Billing
UAE_VAT_PERCENT=5
BILLING_PDF_STORAGE_PATH=./tmp/invoices

# Packages module
PACKAGES_DEFAULT_CURRENCY=USD

# AI itinerary generator
OPENAI_API_KEY=
AI_ITINERARY_MODEL=gpt-4.1-mini
AI_ITINERARY_RATE_LIMIT_PER_MINUTE=30

# Destinations & Attractions
GETYOURGUIDE_API_KEY=
VIATOR_API_KEY=
OPENAI_RECOMMENDATION_MODEL=gpt-4.1-mini
NEXT_PUBLIC_MAP_PROVIDER=mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
IMAGE_CDN_BASE_URL=
REDIS_URL=redis://localhost:6379
