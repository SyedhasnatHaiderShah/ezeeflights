# ── Core ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/ezeeflights
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=14
AUTH_ENCRYPTION_KEY=replace-with-64-hex-chars
BACKUP_CODE_PEPPER=replace-with-random-string
TOTP_ISSUER=ezeeFlights

# ── Google OAuth ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
FRONTEND_OAUTH_REDIRECT=http://localhost:3000/auth/callback

# ── Payments ─────────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYTABS_SERVER_KEY=
PAYTABS_PROFILE_ID=
TABBY_PUBLIC_KEY=
TABBY_SECRET_KEY=
TAMARA_API_KEY=
TAMARA_MERCHANT_URL=

# ── Notifications ────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@ezeeflights.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1...
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── GDS / Travel APIs ────────────────────────────────────────────
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test
BOOKING_COM_API_KEY=
EXPEDIA_API_KEY=
GETYOURGUIDE_API_KEY=
VIATOR_API_KEY=

# ── AI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_ITINERARY_MODEL=gpt-4o
OPENAI_RECOMMENDATION_MODEL=gpt-4o-mini

# ── Storage ───────────────────────────────────────────────────────
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
BILLING_PDF_STORAGE_PATH=./storage/billing
INSURANCE_DOCS_STORAGE_PATH=./storage/insurance

# ── Billing / Tax ────────────────────────────────────────────────
SUPPLIER_VAT_TRN=

# ── Seeder (dev only) ────────────────────────────────────────────
SEED_ADMIN_PASSWORD=Admin@123456
SEED_USER_PASSWORD=User1@123456
ADMIN_EMAILS=admin@ezeeflights.com

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
INTERNAL_API_BASE_URL=http://localhost:4000
