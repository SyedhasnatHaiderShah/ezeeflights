# ─── Backend API ──────────────────────────────────────────────────────────────
# Public URL used by browser-side requests (proxied via /api/v1/[[...path]])
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/v1

# Internal URL used by Next.js server-side fetches (faster, bypasses proxy)
INTERNAL_API_BASE_URL=http://localhost:4000/v1

# ─── AI Recommendations ───────────────────────────────────────────────────────
# Google Gemini API key (used by GeminiRecommendations component)
# Leave empty to disable AI destination recommendations
GEMINI_API_KEY=

# ─── Map Provider ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAP_PROVIDER=mapbox

# ─── Auth Cookies ─────────────────────────────────────────────────────────────
JWT_REFRESH_DAYS=14
