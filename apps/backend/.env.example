# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# ─── Database & Cache ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/ezeeflights
REDIS_URL=redis://localhost:6379

# ─── Auth & Security ──────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_DAYS=14
AUTH_ENCRYPTION_KEY=your-32-char-encryption-key-here
TOTP_ISSUER=ezeeFlights

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/v1/auth/google/callback
FRONTEND_OAUTH_REDIRECT=http://localhost:3000/auth/callback

# ─── Amadeus (Flight Search) ──────────────────────────────────────────────────
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test   # test | production

# ─── OpenAI (AI Features) ─────────────────────────────────────────────────────
OPENAI_API_KEY=
AI_ITINERARY_MODEL=gpt-4o
OPENAI_RECOMMENDATION_MODEL=gpt-4o-mini

# ─── Payment: Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Payment: PayTabs ─────────────────────────────────────────────────────────
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=

# ─── Payment: Tabby (BNPL) ────────────────────────────────────────────────────
TABBY_PUBLIC_KEY=
TABBY_SECRET_KEY=
TABBY_API_BASE_URL=https://api.tabby.ai

# ─── Payment: Tamara (BNPL) ───────────────────────────────────────────────────
TAMARA_API_KEY=
TAMARA_MERCHANT_URL=https://your-domain.com

# ─── Payment (general) ────────────────────────────────────────────────────────
PAYMENT_PROVIDER=STRIPE       # STRIPE | PAYTABS | TABBY | TAMARA
ENABLE_LEGACY_PAYMENT_BRIDGE=false

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ─── Email (SMTP fallback) ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# ─── SMS / WhatsApp (Twilio) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=

# ─── Hotel Providers ──────────────────────────────────────────────────────────
BOOKING_COM_API_KEY=
BOOKING_COM_BASE_URL=https://distribution-xml.booking.com
EXPEDIA_API_KEY=
EXPEDIA_BASE_URL=https://api.expediagroup.com

# ─── Destinations / Tours ─────────────────────────────────────────────────────
GETYOURGUIDE_API_KEY=

# ─── File Storage ─────────────────────────────────────────────────────────────
BILLING_PDF_STORAGE_PATH=./storage/billing
INSURANCE_DOCS_STORAGE_PATH=./storage/insurance

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@yourdomain.com
